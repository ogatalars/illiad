# Illiad — desktop configuration example.
# Copy to `.env` and fill what you need. Everything here has a sane default,
# so the app also runs with NO .env at all.

# --- Networking (loopback only; do not expose to 0.0.0.0 on a desktop) ---
APP_BIND=127.0.0.1
APP_PORT=7000

# --- Local single-user desktop: skip the login wall. Safe ONLY because the
#     backend binds to loopback. Set to true if you want a password. ---
AUTH_ENABLED=false

# --- Data directory (SQLite, caches, vector store). Leave unset to use the
#     per-user default (~/Library/Application Support/illiad, %LOCALAPPDATA%\illiad,
#     ~/.local/share/illiad, depending on OS). ---
# ODYSSEUS_DATA_DIR=/absolute/path/to/data

# --- Vector store: in-process, no container. Set to "http" only if you run a
#     standalone ChromaDB service. ---
CHROMADB_MODE=embedded

# --- Models (agents). The app uses an OpenAI-compatible endpoint. For OpenAI,
#     set the key below. Local models via Ollama need no key — just run Ollama
#     and point the base URL at it. Other providers (Anthropic, gateways) are
#     configured under Settings inside the app (endpoint + key), which persists
#     the key encrypted in your data dir. ---
# OPENAI_API_KEY=sk-...
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# --- Web search / deep research. Optional: DuckDuckGo works with NO key and
#     is a fine default. Add a provider key here (or in Settings -> Search) for
#     better results. SearXNG is NOT used in the desktop build. ---
# DATA_BRAVE_API_KEY=...
# TAVILY_API_KEY=...
# SERPER_API_KEY=...
# GOOGLE_API_KEY=...
# GOOGLE_PSE_CX=...

# --- Webview backend override (Linux). Leave unset for auto (WebKitGTK).
#     Set to "qt" to use Qt/QtWebEngine instead (needs PySide6 installed). ---
# ILLIAD_WEBVIEW_GUI=qt
